# Alembic Dashboard — API keys
# install.sh copies this file to config/.env (chmod 600). Never commit config/.env.
# See README.md and docs/SLACK_SETUP.md for setup details.

# GitHub — PAT with "repo" scope. Create at https://github.com/settings/tokens
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=<paste-ghp-token-here>

# GitHub org for code search (optional; default: twothinkinc)
# GITHUB_ORG=twothinkinc

# Linear — Personal API key. Create at https://linear.app/settings/api
LINEAR_API_KEY=<paste-lin_api-key-here>

# Outline wiki — base URL ends in /api
OUTLINE_BASE_URL=https://wiki.example.com/api
OUTLINE_API_KEY=<paste-ol_api-key-here>

# Slack — User token (xoxp-…). See docs/SLACK_SETUP.md for scopes
SLACK_USER_TOKEN=<paste-xoxp-token-here>

# Ollama — API key (only needed for hosted Ollama; local install ignores this)
OLLAMA_API_KEY=

# Optional: where to scan for git repos (default: ~/src/alembic)
# REPOS_DIR=/Users/you/src/your-org

# Optional: orphan-branch threshold for github-prs plugin (default: 14 days)
# ORPHAN_BRANCH_MAX_DAYS=14
